<Window x:Class="POE2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot" Height="550" Width="700" 
        Background="#0d1b2a" WindowStartupLocation="CenterScreen">

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1b263b" Padding="10">
            <StackPanel>
                <TextBlock Text="Cybersecurity Awareness Chatbot" 
                           Foreground="#00ff88" FontSize="20" FontWeight="Bold" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Cybersecurity Awareness Assistant" 
                           Foreground="White" FontSize="12" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Your Personal Security Guide" 
                           Foreground="Gray" FontSize="10" 
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Background="#0d1b2a" Foreground="White">

            <TabItem Header="Chat">
                <Grid Background="#0d1b2a" Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                        <Button Content="Hello" Width="80" Margin="3" Click="Hello_Click"/>
                        <Button Content="Clear" Width="80" Margin="3" Click="Clear_Click"/>
                        <Button Content="Show Images" Width="90" Margin="3" Click="ShowImages_Click"/>
                    </StackPanel>

                    <TextBox x:Name="ChatBox" Grid.Row="1" IsReadOnly="True"
                             Background="#1b263b" Foreground="White" FontSize="13"
                             TextWrapping="Wrap" AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"/>

                    <Grid Grid.Row="2" Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="InputBox" Height="35" FontSize="14" 
                                 KeyDown="InputBox_KeyDown" VerticalContentAlignment="Center"/>
                        <Button Grid.Column="1" Content="SEND" Width="80" Height="35" 
                                Background="#00c853" Foreground="White" FontWeight="Bold" 
                                Click="Send_Click" Margin="5,0,0,0"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Tasks">
                <TextBox x:Name="TaskBox" IsReadOnly="True" Margin="10"
                         Background="#1b263b" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
            </TabItem>

            <TabItem Header="2FA Quiz">
                <TextBox x:Name="QuizBox" IsReadOnly="True" Margin="10"
                         Background="#1b263b" Foreground="White" FontSize="13" TextWrapping="Wrap"/>
            </TabItem>

            <TabItem Header="Activity Log">
                <TextBox x:Name="LogBox" IsReadOnly="True" Margin="10"
                         Background="#1b263b" Foreground="LightGreen" FontFamily="Consolas"/>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>    